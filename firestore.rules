rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getAccessCode() {
      return exists(/databases/$(database)/documents/sessions/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/sessions/$(request.auth.uid)).data.accessCode 
        : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == "kosawaung.apple@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "saw_vlogs_2026@vbs.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "hankozinsa@gmail.com" && request.auth.token.email_verified == true) ||
        (getAccessCode() == 'saw_vlogs_2026') ||
        (getAccessCode() == 'SAW-ADMIN-2026') ||
        (getAccessCode() != null && 
         exists(/databases/$(database)/documents/vlogs_users/$(getAccessCode())) &&
         get(/databases/$(database)/documents/vlogs_users/$(getAccessCode())).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isDocOwner(userId) {
      return isSignedIn() && (getAccessCode() == userId || request.auth.uid == userId);
    }

    function isValidAuthorizedUser(data) {
      return data.keys().hasAll(['isActive', 'role', 'createdAt']) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() > 0 && data.userId.size() < 128)) &&
             data.isActive is bool &&
             data.role in ['admin', 'user'];
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['userId', 'text', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 128 &&
             data.text is string && data.text.size() <= 60000;
    }

    function isValidPronunciationRule(data) {
      return data.keys().hasAll(['original', 'replacement']) &&
             data.original is string && data.original.size() > 0 && data.original.size() < 500 &&
             data.replacement is string && data.replacement.size() < 500;
    }

    function isValidUserControl(data) {
      return data.keys().hasAll(['vbsId', 'dailyUsage', 'lastUsedDate', 'isUnlimited', 'isBlocked']) &&
             data.vbsId is string && data.vbsId.size() > 0 && data.vbsId.size() < 128 &&
             data.dailyUsage is number &&
             data.lastUsedDate is string &&
             data.isUnlimited is bool &&
             data.isBlocked is bool;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['vbsId', 'type', 'details', 'createdAt']) &&
             data.vbsId is string && data.vbsId.size() > 0 &&
             data.type is string &&
             data.details is string;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['accessCode', 'createdAt']) &&
             data.accessCode is string && data.accessCode.size() > 0 && data.accessCode.size() < 128;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sessions/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid && isValidSession(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == uid && isValidSession(incoming());
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }

    match /vlogs_users/{accessCode} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      allow create: if isValidId(accessCode) && (isAdmin() || 
                       (accessCode == 'SAW-ADMIN-2026' && !exists(/databases/$(database)/documents/vlogs_users/SAW-ADMIN-2026)) ||
                       (accessCode == 'saw_vlogs_2026' && !exists(/databases/$(database)/documents/vlogs_users/saw_vlogs_2026))) && 
                       isValidAuthorizedUser(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isValidId(accessCode) && isSignedIn() && (
        isAdmin() || 
        (
          getAccessCode() == accessCode &&
          incoming().role == existing().role &&
          incoming().isActive == existing().isActive &&
          (!('api_key_stored' in incoming()) || incoming().api_key_stored is string)
        )
      );
      
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      allow get: if isValidId(historyId) && isSignedIn() && (isDocOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == getAccessCode() || resource.data.userId == request.auth.uid);
      
      allow create: if isValidId(historyId) && isSignedIn() && isValidHistoryItem(incoming()) && (incoming().userId == getAccessCode() || incoming().userId == request.auth.uid) && incoming().createdAt == request.time;
      allow update: if isValidId(historyId) && isSignedIn() && isValidHistoryItem(incoming()) && (isDocOwner(existing().userId) || isAdmin()) && incoming().userId == existing().userId;
      allow delete: if isValidId(historyId) && isSignedIn() && (isDocOwner(existing().userId) || isAdmin());
    }

    match /globalRules/{ruleId} {
      allow read: if isSignedIn();
      allow create: if isValidId(ruleId) && isAdmin() && isValidPronunciationRule(incoming());
      allow update: if isValidId(ruleId) && isAdmin() && isValidPronunciationRule(incoming());
      allow delete: if isValidId(ruleId) && isAdmin();
    }

    match /settings/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system_config/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow get: if isValidId(userId) && (isAdmin() || (isSignedIn() && request.auth.uid == userId));
      allow list: if isAdmin();
      allow write: if isValidId(userId) && (isAdmin() || (isSignedIn() && request.auth.uid == userId));
    }

    match /user_controls/{vbsId} {
      allow read: if isValidId(vbsId) && isSignedIn();
      
      allow create: if isValidId(vbsId) && isSignedIn() && (isAdmin() || (isValidUserControl(incoming()) && incoming().vbsId == vbsId));
      
      allow update: if isValidId(vbsId) && isSignedIn() && (
        isAdmin() || 
        (
          isValidUserControl(incoming()) &&
          incoming().vbsId == existing().vbsId &&
          incoming().isUnlimited == existing().isUnlimited &&
          incoming().isBlocked == existing().isBlocked
        )
      );
      
      allow delete: if isValidId(vbsId) && isAdmin();
    }

    match /test/{docId} {
      allow read: if true; 
      allow write: if false;
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isValidId(logId) && isSignedIn() && isValidActivityLog(incoming()) && incoming().vbsId == getAccessCode() && incoming().createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
